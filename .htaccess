# BowlsTracker Security Configuration

# Force HTTPS on production domain
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP_HOST} bowlstracker\.co\.za [NC]
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
</IfModule>

# Block access to sensitive files
<FilesMatch "^\.env|\.env\..*|config\.php|config\.example\.php$">
    Require all denied
</FilesMatch>

# Pass Authorization header through to PHP (Apache CGI/FastCGI strips it by default)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTP:Authorization} .
    RewriteRule ^ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
</IfModule>

# Block access to includes directory (PHP files should only be included, not accessed directly)
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct access to includes directory
    RewriteRule ^includes/ - [F,L]

    # Block direct access to sql directory
    RewriteRule ^sql/ - [F,L]
</IfModule>

# Prevent directory listing
Options -Indexes

# Disable server signature
ServerSignature Off

# Set security headers
<IfModule mod_headers.c>
    # Prevent MIME type sniffing
    Header set X-Content-Type-Options "nosniff"

    # Enable XSS filter
    Header set X-XSS-Protection "1; mode=block"

    # Prevent clickjacking
    Header set X-Frame-Options "SAMEORIGIN"

    # Referrer policy
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # HSTS — tell browsers to always use HTTPS (1 year)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Content Security Policy
    # script-src 'unsafe-inline' is required while inline <script> blocks exist in PHP pages
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self' https://graph.facebook.com; manifest-src 'self'; worker-src 'self'; frame-ancestors 'none'"
</IfModule>

# Protect uploads directory - only allow image files
<IfModule mod_rewrite.c>
    RewriteCond %{REQUEST_URI} ^/uploads/
    RewriteCond %{REQUEST_URI} !\.(jpg|jpeg|png|gif|webp)$ [NC]
    RewriteRule .* - [F,L]
</IfModule>
