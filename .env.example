# BowlsTracker Environment Configuration
# Copy this file to .env and fill in your values

# Database
DB_HOST=localhost
DB_NAME=rolbal
DB_USER=root
DB_PASS=

# App
APP_NAME=BowlsTracker
APP_URL=https://bowlstracker.co.za

# Environment (set to false in production!)
DEBUG=false

# WhatsApp Cloud API (Meta Business)
# Get these from https://developers.facebook.com/apps/
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token
WHATSAPP_ACCESS_TOKEN=your_meta_access_token
WHATSAPP_PHONE_ID=your_phone_number_id
WHATSAPP_APP_SECRET=your_app_secret

# Production Deployment (PSCP)
DEPLOY_HOST=your_host
DEPLOY_PORT=2222
DEPLOY_USER=your_username
DEPLOY_PASS=your_password
DEPLOY_PATH=public_html/
